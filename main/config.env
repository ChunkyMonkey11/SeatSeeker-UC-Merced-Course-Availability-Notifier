# SeatSeeker Configuration
# Copy this file to .env and update with your settings

# Database Configuration
# For Supabase/Postgres, set DATABASE_URL and leave DATABASE_PATH unused.
DATABASE_URL=
DATABASE_PATH=database.db

# Email Configuration (Gmail recommended)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# Scheduler Configuration
CHECK_INTERVAL=300
ERROR_RETRY_INTERVAL=600
LOG_LEVEL=INFO
# Notification queue strategy:
# - all: notify every subscriber for an open CRN
# - fifo: notify only first N in queue (N from NOTIFY_BATCH_SIZE, default 1)
NOTIFY_MODE=all
NOTIFY_BATCH_SIZE=0
# Priority delivery:
# Global priority emails (optional), comma-separated.
PRIORITY_EMAILS=
# CRN-specific priority map format:
# 12345:you@example.com|friend@example.com;23456:vip@example.com
PRIORITY_EMAILS_BY_CRN=
# After priority emails are sent for an open CRN, wait this many minutes before notifying non-priority subscribers.
PRIORITY_HOLD_MINUTES=60

# Checker Configuration
TERM_CODE=202630
# Leave empty to query all known subjects.
SUBJECT_CODES=
REQUEST_TIMEOUT_SECONDS=20

# Web Dashboard Configuration
DASHBOARD_PORT=5000
DEBUG_MODE=False
MAX_REQUEST_BODY_BYTES=16384
GLOBAL_RATE_LIMIT=120 per minute
SUBSCRIPTION_POST_RATE=10 per minute
SUBSCRIPTION_DELETE_RATE=20 per minute
# Required admin key for reading subscription lists via GET /api/subscriptions.
# Send it as header: X-SeatSeeker-Admin-Key
ADMIN_API_KEY=
# Security / Debug
# Keep false in production to avoid exposing internal DB errors.
EXPOSE_INTERNAL_ERRORS=false
